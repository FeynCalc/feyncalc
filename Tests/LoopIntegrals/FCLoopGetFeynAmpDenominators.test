(* :Summary:  Framework independent unit tests for FCLoopGetFeynAmpDenominators			*)

(* ------------------------------------------------------------------------ *)

Tests`LoopIntegrals`fcstFCLoopGetFeynAmpDenominators =
({{"fcstFCLoopGetFeynAmpDenominators-ID1",
"FCLoopGetFeynAmpDenominators[c0 FAD[p]+c1 FAD[k1]+c2 FAD[k1+p]+c3 \
FAD[{k1,m}]+c4 FAD[{k1+p,m}],{k1},denHead,FCE->True]",
"{c1*denHead[SFAD[{{k1, 0}, {0, 1}, 1}]] + c3*denHead[SFAD[{{k1, 0}, \
{m^2, 1}, 1}]] + c2*denHead[SFAD[{{k1 + p, 0}, {0, 1}, 1}]] + \
c4*denHead[SFAD[{{k1 + p, 0}, {m^2, 1}, 1}]] + c0*SFAD[{{p, 0}, {0, 1}, \
1}], {denHead[SFAD[{{k1, 0}, {0, 1}, 1}]], denHead[SFAD[{{k1, 0}, \
{m^2, 1}, 1}]], denHead[SFAD[{{k1 + p, 0}, {0, 1}, 1}]], \
denHead[SFAD[{{k1 + p, 0}, {m^2, 1}, 1}]]}}"}, \
{"fcstFCLoopGetFeynAmpDenominators-ID2",
"FCLoopGetFeynAmpDenominators[c0 FAD[p]+c1 FAD[k1]+c2 FAD[k1+p]+c3 \
FAD[{k1,m}]+c4 \
FAD[{k1+p,m}],{k1},denHead,\[IndentingNewLine]Momentum->{p},FCE->True]",
	"{c2*denHead[SFAD[{{k1 + p, 0}, {0, 1}, 1}]] + \
c4*denHead[SFAD[{{k1 + p, 0}, {m^2, 1}, 1}]] + c1*SFAD[{{k1, 0}, {0, \
1}, 1}] + c3*SFAD[{{k1, 0}, {m^2, 1}, 1}] + c0*SFAD[{{p, 0}, {0, 1}, \
1}], {denHead[SFAD[{{k1 + p, 0}, {0, 1}, 1}]], denHead[SFAD[{{k1 + p, \
0}, {m^2, 1}, 1}]]}}"}, {"fcstFCLoopGetFeynAmpDenominators-ID3",
"FCLoopGetFeynAmpDenominators[c0 FAD[p]+c1 FAD[k1]+c2 FAD[k1+p]+c3 \
FAD[{k1,m}]+c4 \
FAD[{k1+p,m}],{k1},denHead,\[IndentingNewLine]\"Massless\"\
->True,FCE->True]",
"{c1*denHead[SFAD[{{k1, 0}, {0, 1}, 1}]] + c2*denHead[SFAD[{{k1 + \
p, 0}, {0, 1}, 1}]] + c3*SFAD[{{k1, 0}, {m^2, 1}, 1}] + c0*SFAD[{{p, \
0}, {0, 1}, 1}] + c4*SFAD[{{k1 + p, 0}, {m^2, 1}, 1}], \
{denHead[SFAD[{{k1, 0}, {0, 1}, 1}]], denHead[SFAD[{{k1 + p, 0}, {0, \
1}, 1}]]}}"}, {"fcstFCLoopGetFeynAmpDenominators-ID4",
"FCLoopGetFeynAmpDenominators[c0 FAD[p]+c1 FAD[k1]+c2 FAD[k1+p]+c3 \
FAD[{k1,m}]+c4 \
FAD[{k1+p,m}],{k1},denHead,Momentum->{p},\"Massless\"->True,FCE->True]",
	"{c1*denHead[SFAD[{{k1, 0}, {0, 1}, 1}]] + c2*denHead[SFAD[{{k1 + \
p, 0}, {0, 1}, 1}]] + c4*denHead[SFAD[{{k1 + p, 0}, {m^2, 1}, 1}]] + \
c3*SFAD[{{k1, 0}, {m^2, 1}, 1}] + c0*SFAD[{{p, 0}, {0, 1}, 1}], \
{denHead[SFAD[{{k1, 0}, {0, 1}, 1}]], denHead[SFAD[{{k1 + p, 0}, {0, \
1}, 1}]], denHead[SFAD[{{k1 + p, 0}, {m^2, 1}, 1}]]}}"}});
