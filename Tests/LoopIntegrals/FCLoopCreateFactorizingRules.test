Tests`LoopIntegrals`fcstFCLoopCreateFactorizingRules =
({{"fcstFCLoopCreateFactorizingRules-ID1",
"FCLoopCreateFactorizingRules[{GLI[prop2Ltopo31313,{0,0,1,0,1}]},{F\
CTopology[prop2Ltopo31313,{SFAD[{{I p1,0},{-m3^2,-1},1}],SFAD[{{I \
(p1+q1),0},{-m1^2,-1},1}],SFAD[{{I p3,0},{-m3^2,-1},1}],SFAD[{{I \
(p3+q1),0},{-m1^2,-1},1}],SFAD[{{I \
(p1-p3),0},{-m3^2,-1},1}]},{p1,p3},{q1},{SPD[q1,q1]->m1^2},{}]},FCE->T\
rue,FCVerbose->-1]",
"{{GLI[prop2Ltopo31313, {0, 0, 1, 0, 1}] -> GLI[\"loopint1\", \
{1}]^2}, {GLI[\"loopint1\", {1}]}, {FCTopology[\"loopint1\", \
{SFAD[{{I*p1, 0}, {-m3^2, -1}, 1}]}, {p1}, {}, {SPD[q1, q1] -> m1^2}, \
{}]}}"}, {"fcstFCLoopCreateFactorizingRules-ID2",
"FCLoopCreateFactorizingRules[{GLI[prop3L1topo00112211,{0,0,1,1,1,0\
,1,0,0}]},{FCTopology[prop3L1topo00112211,{SFAD[{{\[ImaginaryI] \
p1,0},{0,1},1}],SFAD[{{\[ImaginaryI] p2,0},{0,1},1}],SFAD\
[{{\[ImaginaryI] p3,0},{-\!\(\*SuperscriptBox[\(m1\), \
\(2\)]\),1},1}],SFAD[{{\[ImaginaryI] \
(p1-p2),0},{-\!\(\*SuperscriptBox[\(m1\), \(2\)]\),1},1}],SFAD\
[{{\[ImaginaryI] (p2-p3),0},{0,1},1}],SFAD[{{\[ImaginaryI] \
(p1+q1),0},{-\!\(\*SuperscriptBox[\(m2\), \(2\)]\),1},1}],SFAD\
[{{\[ImaginaryI] (p2+q1),0},{-\!\(\*SuperscriptBox[\(m1\), \
\(2\)]\),1},1}],SFAD[{{\[ImaginaryI] \
(p3+q1),0},{-\!\(\*SuperscriptBox[\(m1\), \
\(2\)]\),1},1}],SFAD[{{0,-p1.p3},{0,1},1}]},{p1,p2,p3},{q1},{},{}]},FC\
E->True,FCVerbose->-1]",
"{{GLI[prop3L1topo00112211, {0, 0, 1, 1, 1, 0, 1, 0, 0}] -> \
GLI[\"loopint1\", {1}]*GLI[\"loopint2\", {1, 1, 1}]}, {GLI[\"loopint1\
\", {1}], GLI[\"loopint2\", {1, 1, 1}]}, {FCTopology[\"loopint1\", \
{SFAD[{{I*p1, 0}, {-m1^2, 1}, 1}]}, {p1}, {}, {}, {}], \
FCTopology[\"loopint2\", {SFAD[{{I*p3, 0}, {-m1^2, 1}, 1}], \
SFAD[{{I*(p2 + q1), 0}, {-m1^2, 1}, 1}], SFAD[{{I*(p2 - p3), 0}, {0, \
1}, 1}]}, {p2, p3}, {q1}, {}, {}]}}"}, \
{"fcstFCLoopCreateFactorizingRules-ID3",
