p3, p4}, {}}}}"}, {"fcstFCLoopFactorizingSplit-ID11",
"FCLoopFactorizingSplit[{GLI[prop3L3topo22002112,{0,0,1,1,1,0,1,1,0\
}]},{FCTopology[prop3L3topo22002112,{SFAD[{{\[ImaginaryI] \
p1,0},{-\!\(\*SuperscriptBox[\(m2\), \(2\)]\),1},1}],SFAD\
[{{\[ImaginaryI] (p1-p4),0},{-\!\(\*SuperscriptBox[\(m2\), \
\(2\)]\),1},1}],SFAD[{{\[ImaginaryI] p3,0},{0,1},1}],SFAD\
[{{\[ImaginaryI] p4,0},{0,1},1}],SFAD[{{\[ImaginaryI] \
(p1-p3-p4),0},{-\!\(\*SuperscriptBox[\(m2\), \(2\)]\),1},1}],SFAD\
[{{\[ImaginaryI] (p1+q1),0},{-\!\(\*SuperscriptBox[\(m1\), \
