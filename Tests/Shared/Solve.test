{"fcstSolve2-ID1","Solve2[{2 x == b - w/2, y - d == p}, {x, y}]",
	"{x->1/4 (2 b-w),y->d+p}"},
{"fcstSolve2-ID2","Solve2[x + y, x]",
	"{x->-y}"},
{"fcstSolve2-ID3","Solve2[x + y, x, FinalSubstitutions -> {y -> h}]",
	"{x->-h}"},
{"fcstSolve2-ID4","Solve2[{2 x == b - w/2, y - d == p}, {x, y}, Factoring -> Expand]",
	"{x->b/2-w/4,y->d+p}"},
{"fcstSolve2-ID5","	Solve2[{X3*X5 ==
cC2*X1 + cC1*(X1 + X1^2) + cC3*X9 + cC4*X9 + cC5*X9^2 +
	cC6*(X9 + X1*X9) + cC7*(X9 + X1*X9),
X2*X7 ==
2*cC1*X1 + cC2*X1^2 + 2*cC6*X9 + 2*cC7*X9 + cC3*X1*X9 + cC4*X1*X9 +
	cC5*X9^2,
X4*X6*X7 ==
2*cC1*X9 + cC2*X1*X9 + cC4*X9^2 + 2*cC6*X9^2 + 2*cC7*X9^2 +
	cC3*X1*X9^2 + cC5*X9^3,
X4*X5*X8 ==
cC2*X9 + cC3*X9^2 + cC4*X9^2 + 2*cC7*X9^2 + cC5*X9^3 +
	cC1*(X9 + X1*X9) + cC6*(X9^2 + X1*X9^2),
X3*X6*X8 ==
cC2*X9 + cC3*X9^2 + cC4*X9^2 + 2*cC6*X9^2 + cC5*X9^3 +
	cC1*(X9 + X1*X9) + cC7*(X9^2 + X1*X9^2),
X2*X8^2 ==
2*cC1*X9 + cC2*X1*X9 + cC3*X9^2 + 2*cC6*X9^2 + 2*cC7*X9^2 +
	cC4*X1*X9^2 + cC5*X9^3,
X4*X6*X8^2 ==
2*cC1*X9^2 + cC2*X9^2 + cC3*X9^3 + cC4*X9^3 + 2*cC6*X9^3 +
	2*cC7*X9^3 + cC5*X9^4},
{cC1, cC2, cC3, cC4, cC5, cC6, cC7}]",
	"{cC1 -> -((2*X4*X6*X8^2 - X1*X4*X6*X8^2 - X4*X6*X7*X9 - X4*X5*X8*X9 + X1*X4*X5*X8*X9 - X3*X6*X8*X9 + X1*X3*X6*X8*X9 - X2*X8^2*X9 + X3*X5*X9^2 -
	X1*X3*X5*X9^2 + X2*X7*X9^2)/((2 - X1)*(1 - X1^2)*X9^2)),
cC2 -> -((2*X4*X6*X8^2 - X1*X4*X6*X8^2 + X1*X4*X6*X7*X9 - 2*X4*X5*X8*X9 - 2*X3*X6*X8*X9 + X1*X2*X8^2*X9 + 2*X3*X5*X9^2 - X1*X2*X7*X9^2)/
	((2 - X1)*(1 - X1^2)*X9^2)), cC3 -> (4*X4*X6*X8^2 - X1^2*X4*X6*X8^2 - 2*X4*X6*X7*X9 + X1^2*X4*X6*X7*X9 - 2*X4*X5*X8*X9 - 2*X3*X6*X8*X9 +
	X1*X2*X8^2*X9 + 2*X3*X5*X9^2 - X1*X2*X7*X9^2)/((2 - X1)*(1 - X1^2)*X9^3),
cC4 -> (4*X4*X6*X8^2 - X1^2*X4*X6*X8^2 + X1*X4*X6*X7*X9 - 2*X4*X5*X8*X9 - 2*X3*X6*X8*X9 - 2*X2*X8^2*X9 + X1^2*X2*X8^2*X9 + 2*X3*X5*X9^2 -
	X1*X2*X7*X9^2)/((2 - X1)*(1 - X1^2)*X9^3),
cC5 -> -((8*X4*X6*X8^2 + 6*X1*X4*X6*X8^2 + X1^2*X4*X6*X8^2 - 2*X4*X6*X7*X9 - X1*X4*X6*X7*X9 - 4*X4*X5*X8*X9 - 2*X1*X4*X5*X8*X9 - 4*X3*X6*X8*X9 -
	2*X1*X3*X6*X8*X9 - 2*X2*X8^2*X9 - X1*X2*X8^2*X9 + 2*X3*X5*X9^2 + X2*X7*X9^2)/((1 - X1^2)*X9^4)),
cC6 -> (4*X4*X6*X8^2 - X1^2*X4*X6*X8^2 - X4*X6*X7*X9 - 3*X4*X5*X8*X9 + X1^2*X4*X5*X8*X9 - X3*X6*X8*X9 + X1*X3*X6*X8*X9 - X2*X8^2*X9 + X3*X5*X9^2 -
	X1*X3*X5*X9^2 + X2*X7*X9^2)/((2 - X1)*(1 - X1^2)*X9^3),
cC7 -> (4*X4*X6*X8^2 - X1^2*X4*X6*X8^2 - X4*X6*X7*X9 - X4*X5*X8*X9 + X1*X4*X5*X8*X9 - 3*X3*X6*X8*X9 + X1^2*X3*X6*X8*X9 - X2*X8^2*X9 + X3*X5*X9^2 -
	X1*X3*X5*X9^2 + X2*X7*X9^2)/((2 - X1)*(1 - X1^2)*X9^3)}"},
